# ===========================================
# Database Configuration
# ===========================================

# Local development: Uses SQLite automatically (no config needed)

# Production (Turso): Get credentials from https://turso.tech
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

# ===========================================
# AI Provider (Azure OpenAI)
# ===========================================

# Set in Vercel env vars — not needed locally
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-api-key

# ===========================================
# Email Finder (Ninjer API)
# ===========================================

# NINJER_API_KEY=your-api-key

