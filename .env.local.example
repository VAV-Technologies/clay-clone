# ===========================================
# Database Configuration
# ===========================================

# Local development: Uses SQLite automatically (no config needed)

# Production (Turso): Get credentials from https://turso.tech
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

# ===========================================
# AI Provider (Azure OpenAI)
# ===========================================

# Set in Vercel env vars — not needed locally
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-api-key

# ===========================================
# External API Access
# ===========================================

# DATAFLOW_API_KEY=your-api-key-here

# ===========================================
# Email Finder (Ninjer API)
# ===========================================

# NINJER_API_KEY=your-api-key
# Base URL of the email-finder (MailTester Ninja) service. Defaults to the Azure
# Container Apps deployment; override only if the service moves.
# NINJER_BASE_URL=https://email-finder.delightfulbeach-10f489d6.eastus2.azurecontainerapps.io

# ===========================================
# Clay People Search (Add Data feature)
# ===========================================

# CLAY_EMAIL=your-clay-email@example.com
# CLAY_PASSWORD=your-clay-password
# CLAY_WORKSPACE_ID=your-workspace-id

