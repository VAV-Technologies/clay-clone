#!/usr/bin/env node
// agent-x — terminal client for DataFlow Agent X (GTM Campaign Builder).
//
// Drives the same /api/agent/conversations endpoints the web UI uses, so the
// full chat -> approve -> preview -> launch flow is available from the
// terminal (including from inside Claude Code via its Bash tool).
//
// Install: curl -fsSL https://dataflow-pi.vercel.app/cli/install.sh | bash
//          (PowerShell)  irm https://dataflow-pi.vercel.app/cli/install.ps1 | iex
//
// Usage:
//   agent-x new   "<prompt>"        [--model <id>]
//   agent-x turn  <id> "<message>"  [--model <id>]
//   agent-x get   <id>
//   agent-x preview <id>
//   agent-x launch  <id>            [--limit <n>]
//   agent-x list
//   agent-x delete <id>
//   agent-x set-key <token>
//   agent-x set-base-url <url>
//
// Config precedence: process env > ~/.config/agent-x/env > defaults.

import { readFileSync, writeFileSync, mkdirSync, existsSync } from 'node:fs';
import { join } from 'node:path';
import { homedir } from 'node:os';

const CONFIG_DIR = join(homedir(), '.config', 'agent-x');
const CONFIG_FILE = join(CONFIG_DIR, 'env');

function loadConfigFile() {
  if (!existsSync(CONFIG_FILE)) return;
  try {
    const text = readFileSync(CONFIG_FILE, 'utf8');
    for (const raw of text.split('\n')) {
      const line = raw.trim();
      if (!line || line.startsWith('#')) continue;
      const eq = line.indexOf('=');
      if (eq === -1) continue;
      const key = line.slice(0, eq).trim();
      let value = line.slice(eq + 1).trim();
      if ((value.startsWith('"') && value.endsWith('"')) || (value.startsWith("'") && value.endsWith("'"))) {
        value = value.slice(1, -1);
      }
      if (!(key in process.env)) process.env[key] = value;
    }
  } catch {
    /* ignore */
  }
}
loadConfigFile();

const BASE_URL = process.env.DATAFLOW_BASE_URL || 'https://dataflow-pi.vercel.app';
const API_KEY = process.env.DATAFLOW_API_KEY || '';

function headers() {
  const h = { 'Content-Type': 'application/json' };
  if (API_KEY) h.Authorization = `Bearer ${API_KEY}`;
  return h;
}

async function request(method, path, body) {
  const res = await fetch(`${BASE_URL}${path}`, {
    method,
    headers: headers(),
    body: body === undefined ? undefined : JSON.stringify(body),
  });
  const text = await res.text();
  let data = null;
  try { data = text ? JSON.parse(text) : null; } catch { data = { raw: text }; }
  if (!res.ok) {
    const msg = (data && data.error) || text.slice(0, 400) || res.statusText;
    throw new Error(`${method} ${path} -> ${res.status}: ${msg}`);
  }
  return data;
}

function parseFlags(args) {
  const positional = [];
  const flags = {};
  for (let i = 0; i < args.length; i++) {
    const a = args[i];
    if (a.startsWith('--')) {
      const key = a.slice(2);
      const next = args[i + 1];
      if (next === undefined || next.startsWith('--')) {
        flags[key] = 'true';
      } else {
        flags[key] = next;
        i++;
      }
    } else {
      positional.push(a);
    }
  }
  return { positional, flags };
}

function summarizePlan(plan) {
  if (!plan || typeof plan !== 'object') return '';
  const lines = [];
  lines.push(`  plan: ${plan.name ?? '(unnamed)'}  source=${plan.source ?? '?'}`);
  if (plan.rationale) lines.push(`  rationale: ${String(plan.rationale).slice(0, 200)}`);
  if (Array.isArray(plan.stages)) {
    plan.stages.forEach((stage, i) => {
      const stepCount = Array.isArray(stage?.steps) ? stage.steps.length : 0;
      lines.push(`  stage ${i + 1}: ${stage?.title ?? '(no title)'}  (${stepCount} step${stepCount === 1 ? '' : 's'})`);
      if (Array.isArray(stage?.steps)) {
        for (const step of stage.steps) {
          lines.push(`    - ${step?.type ?? '?'}`);
        }
      }
    });
  }
  return lines.join('\n');
}

function printChatResponse(data) {
  console.log(`conversation: ${data.conversationId}`);
  if (data.title) console.log(`title:        ${data.title}`);
  console.log(`status:       ${data.status}`);
  console.log(`nextAction:   ${data.nextAction}`);
  const assistant = Array.isArray(data.messages)
    ? data.messages.filter(m => m.role === 'assistant').slice(-1)[0]
    : null;
  if (assistant?.content) {
    console.log('\nassistant:');
    console.log(assistant.content);
  }
  if (Array.isArray(data.clarifyingQuestions) && data.clarifyingQuestions.length) {
    console.log('\nclarifying questions:');
    for (const q of data.clarifyingQuestions) console.log(`  - ${q}`);
  }
  if (data.planJson) {
    console.log('\nplan:');
    console.log(summarizePlan(data.planJson));
  }
}

function writeConfig(key, value) {
  mkdirSync(CONFIG_DIR, { recursive: true });
  const existing = existsSync(CONFIG_FILE) ? readFileSync(CONFIG_FILE, 'utf8').split('\n') : [];
  const next = [];
  let replaced = false;
  for (const raw of existing) {
    const line = raw.trim();
    if (!line || line.startsWith('#')) { next.push(raw); continue; }
    const eq = line.indexOf('=');
    if (eq !== -1 && line.slice(0, eq).trim() === key) {
      next.push(`${key}=${value}`);
      replaced = true;
    } else {
      next.push(raw);
    }
  }
  if (!replaced) next.push(`${key}=${value}`);
  writeFileSync(CONFIG_FILE, next.filter(Boolean).join('\n') + '\n', { mode: 0o600 });
}

async function cmdNew(positional, flags) {
  const prompt = positional[0];
  if (!prompt) throw new Error('usage: agent-x new "<prompt>" [--model <id>]');
  const body = { prompt };
  if (flags.model) body.model = flags.model;
  const data = await request('POST', '/api/agent/conversations', body);
  printChatResponse(data);
}

async function cmdTurn(positional, flags) {
  const [convId, message] = positional;
  if (!convId || !message) throw new Error('usage: agent-x turn <id> "<message>" [--model <id>]');
  const body = { message };
  if (flags.model) body.model = flags.model;
  const data = await request('POST', `/api/agent/conversations/${encodeURIComponent(convId)}/turn`, body);
  printChatResponse(data);
}

async function cmdGet(positional) {
  const [convId] = positional;
  if (!convId) throw new Error('usage: agent-x get <id>');
  const data = await request('GET', `/api/agent/conversations/${encodeURIComponent(convId)}`);
  const conv = data.conversation;
  console.log(`conversation: ${conv.id}`);
  console.log(`title:        ${conv.title}`);
  console.log(`status:       ${conv.status}`);
  console.log(`campaignId:   ${conv.campaignId ?? '(none)'}`);
  const lastAssistant = Array.isArray(data.messages)
    ? data.messages.filter(m => m.role === 'assistant').slice(-1)[0]
    : null;
  if (lastAssistant) {
    console.log('\nlast assistant message:');
    console.log(lastAssistant.content);
  }
  if (conv.planJson) {
    console.log('\nplan:');
    console.log(summarizePlan(conv.planJson));
  }
  if (data.campaign) {
    const c = data.campaign;
    console.log('\ncampaign:');
    console.log(`  id:       ${c.id}`);
    console.log(`  status:   ${c.status}`);
    console.log(`  workbook: ${c.workbookId ?? '(none)'}`);
    console.log(`  progress: step ${c.progress?.currentStep ?? '?'} / ${c.progress?.totalSteps ?? '?'}  (${c.progress?.completedSteps ?? 0} complete)`);
    if (Array.isArray(c.steps)) {
      for (const s of c.steps) {
        const tag = s.status === 'complete' ? 'OK' : s.status === 'error' ? 'ERR' : s.status === 'running' ? '..' : '  ';
        console.log(`    [${tag}] ${s.step}. ${s.type}${s.error ? '  err=' + String(s.error).slice(0, 120) : ''}`);
      }
    }
  }
}

async function cmdPreview(positional) {
  const [convId] = positional;
  if (!convId) throw new Error('usage: agent-x preview <id>');
  const data = await request('POST', `/api/agent/conversations/${encodeURIComponent(convId)}/preview`, {});
  console.log(`status:         ${data.status}`);
  console.log(`searchType:     ${data.searchType}`);
  console.log(`estimatedTotal: ${data.estimatedTotal ?? 'n/a'}`);
  console.log(`previewCount:   ${data.previewCount ?? 0}`);
  if (Array.isArray(data.preview) && data.preview.length) {
    console.log('\nfirst 3 preview rows:');
    for (const row of data.preview.slice(0, 3)) {
      console.log('  - ' + JSON.stringify(row).slice(0, 240));
    }
  }
}

async function cmdLaunch(positional, flags) {
  const [convId] = positional;
  if (!convId) throw new Error('usage: agent-x launch <id> [--limit <n>]');
  const body = {};
  if (flags.limit) {
    const n = Number(flags.limit);
    if (!Number.isFinite(n) || n <= 0) throw new Error('--limit must be a positive number');
    body.confirmedLimit = Math.floor(n);
  }
  const data = await request('POST', `/api/agent/conversations/${encodeURIComponent(convId)}/launch`, body);
  console.log(`status:     ${data.status}`);
  console.log(`campaignId: ${data.campaignId}`);
  console.log(`workbook:   ${data.workbookId ?? '(none)'}`);
  console.log(`totalSteps: ${data.totalSteps}`);
  if (data.message) console.log(`message:    ${data.message}`);
}

async function cmdList() {
  const data = await request('GET', '/api/agent/conversations');
  const rows = Array.isArray(data.conversations) ? data.conversations : [];
  if (!rows.length) { console.log('(no conversations)'); return; }
  for (const r of rows) {
    console.log(`${r.id}  ${r.status.padEnd(20)}  ${r.updatedAt}  ${r.title}`);
  }
}

async function cmdDelete(positional) {
  const [convId] = positional;
  if (!convId) throw new Error('usage: agent-x delete <id>');
  const data = await request('DELETE', `/api/agent/conversations/${encodeURIComponent(convId)}`);
  console.log(`deleted: ${convId}  cancelledCampaign=${!!data.cancelledCampaign}`);
}

function cmdSetKey(positional) {
  const [token] = positional;
  if (!token) throw new Error('usage: agent-x set-key <token>');
  writeConfig('DATAFLOW_API_KEY', token);
  console.log(`saved DATAFLOW_API_KEY to ${CONFIG_FILE}`);
}

function cmdSetBaseUrl(positional) {
  const [url] = positional;
  if (!url) throw new Error('usage: agent-x set-base-url <url>');
  writeConfig('DATAFLOW_BASE_URL', url.replace(/\/$/, ''));
  console.log(`saved DATAFLOW_BASE_URL to ${CONFIG_FILE}`);
}

// Parse the api subcommand's argv. METHOD + path are positional; --data,
// --data-file, --query can appear in any order. --query is repeatable.
function parseApiArgs(rest) {
  let method, path;
  let data, dataFile;
  const queries = [];
  let i = 0;
  while (i < rest.length) {
    const a = rest[i];
    if (a === '--data') {
      data = rest[i + 1];
      if (data === undefined) throw new Error('--data requires a value');
      i += 2;
    } else if (a === '--data-file') {
      dataFile = rest[i + 1];
      if (dataFile === undefined) throw new Error('--data-file requires a path');
      i += 2;
    } else if (a === '--query') {
      const q = rest[i + 1];
      if (q === undefined) throw new Error('--query requires a k=v value');
      queries.push(q);
      i += 2;
    } else if (a.startsWith('--')) {
      throw new Error(`unknown flag for api: ${a}`);
    } else if (!method) {
      method = a; i++;
    } else if (!path) {
      path = a; i++;
    } else {
      throw new Error(`unexpected positional argument: ${a}`);
    }
  }
  return { method, path, data, dataFile, queries };
}

async function cmdApi(rest) {
  const { method, path, data, dataFile, queries } = parseApiArgs(rest);
  if (!method || !path) {
    throw new Error('usage: agent-x api <METHOD> <path> [--data <json>] [--data-file <path>] [--query k=v ...]');
  }
  const m = method.toUpperCase();
  const allowed = new Set(['GET', 'POST', 'PUT', 'PATCH', 'DELETE', 'HEAD']);
  if (!allowed.has(m)) throw new Error(`unsupported HTTP method: ${method}`);

  // Defensive: Git Bash / MSYS on Windows rewrites leading "/" args as
  // absolute Windows paths (e.g. "/api/projects" -> "C:/Program Files/
  // Git/api/projects"). If we see that shape, snap back to the
  // /api or /cli segment the user intended.
  let pathOnly = path;
  if (/^[A-Za-z]:[\\/]/.test(pathOnly) || /Program Files/.test(pathOnly) || pathOnly.includes('\\')) {
    const m = pathOnly.replace(/\\/g, '/').match(/\/(api|cli)\/.+$/);
    if (m) pathOnly = m[0];
  }
  if (!pathOnly.startsWith('/')) pathOnly = '/' + pathOnly;
  if (queries.length) {
    const sep = pathOnly.includes('?') ? '&' : '?';
    const qs = queries.map(q => {
      const eq = q.indexOf('=');
      if (eq === -1) return encodeURIComponent(q) + '=';
      return encodeURIComponent(q.slice(0, eq)) + '=' + encodeURIComponent(q.slice(eq + 1));
    }).join('&');
    pathOnly = pathOnly + sep + qs;
  }

  if (data !== undefined && dataFile !== undefined) {
    throw new Error('--data and --data-file are mutually exclusive');
  }
  let body;
  if (data !== undefined) {
    try { JSON.parse(data); } catch (e) {
      throw new Error(`--data is not valid JSON: ${e.message}`);
    }
    body = data;
  } else if (dataFile !== undefined) {
    const raw = readFileSync(dataFile, 'utf8');
    try { JSON.parse(raw); } catch (e) {
      throw new Error(`--data-file contents not valid JSON: ${e.message}`);
    }
    body = raw;
  }
  if (body !== undefined && (m === 'GET' || m === 'HEAD')) {
    throw new Error(`${m} requests cannot have a body — drop --data/--data-file`);
  }

  const res = await fetch(`${BASE_URL}${pathOnly}`, { method: m, headers: headers(), body });
  const text = await res.text();
  let out = text;
  try { out = JSON.stringify(JSON.parse(text), null, 2); } catch { /* keep raw */ }
  process.stdout.write(out);
  if (!out.endsWith('\n')) process.stdout.write('\n');
  if (!res.ok) {
    process.stderr.write(`\n${m} ${pathOnly} -> ${res.status}\n`);
    process.exitCode = 1;
  }
}

async function cmdView(positional, flags) {
  const [tableId] = positional;
  if (!tableId) {
    throw new Error('usage: agent-x view <tableId> [--limit N] [--cols a,b,c] [--filter <json>] [--wide] [--json]');
  }

  // Fetch the column schema for this sheet.
  const colsRes = await fetch(
    `${BASE_URL}/api/columns?tableId=${encodeURIComponent(tableId)}`,
    { headers: headers() }
  );
  if (!colsRes.ok) {
    const text = await colsRes.text();
    throw new Error(`GET /api/columns -> ${colsRes.status}: ${text.slice(0, 300)}`);
  }
  const cols = await colsRes.json();
  if (!Array.isArray(cols) || cols.length === 0) {
    console.log(`(no columns on table ${tableId})`);
    return;
  }
  let displayCols = cols.slice().sort((a, b) => (a.order ?? 0) - (b.order ?? 0));
  if (flags.cols) {
    const wanted = flags.cols.split(',').map(s => s.trim().toLowerCase()).filter(Boolean);
    displayCols = displayCols.filter(c => wanted.some(w => c.name.toLowerCase().includes(w)));
    if (!displayCols.length) {
      throw new Error(`no columns matched --cols=${flags.cols}`);
    }
  }

  // Fetch rows.
  const limit = flags.limit ? Number(flags.limit) : 20;
  if (!Number.isFinite(limit) || limit <= 0) throw new Error('--limit must be a positive number');
  const params = new URLSearchParams({ tableId, limit: String(limit) });
  if (flags.filter) {
    try { JSON.parse(flags.filter); } catch (e) {
      throw new Error(`--filter is not valid JSON: ${e.message}`);
    }
    params.set('filters', flags.filter);
    params.set('filterLogic', 'AND');
  }
  const rowsRes = await fetch(`${BASE_URL}/api/rows?${params.toString()}`, { headers: headers() });
  if (!rowsRes.ok) {
    const text = await rowsRes.text();
    throw new Error(`GET /api/rows -> ${rowsRes.status}: ${text.slice(0, 300)}`);
  }
  const totalHeader = rowsRes.headers.get('x-total-count');
  const filteredHeader = rowsRes.headers.get('x-filtered-count');
  const rows = await rowsRes.json();
  const total = filteredHeader ?? totalHeader ?? String(rows.length);

  if (flags.json) {
    const out = rows.map(r => {
      const o = { _id: r.id };
      for (const c of displayCols) {
        o[c.name] = r.data?.[c.id]?.value ?? null;
      }
      return o;
    });
    console.log(JSON.stringify(out, null, 2));
    return;
  }

  const MAX_W = flags.wide ? 200 : 30;
  const trunc = v => {
    let s = v === null || v === undefined ? '' : typeof v === 'object' ? JSON.stringify(v) : String(v);
    s = s.replace(/\s+/g, ' ').trim();
    if (s.length > MAX_W) s = s.slice(0, MAX_W - 1) + '…';
    return s;
  };

  const head = displayCols.map(c => c.name);
  const body = rows.map(r => displayCols.map(c => trunc(r.data?.[c.id]?.value)));
  const widths = head.map((h, i) =>
    Math.max(h.length, ...body.map(row => row[i].length), 1)
  );
  const pad = (s, w) => s + ' '.repeat(Math.max(0, w - s.length));

  console.log(head.map((h, i) => pad(h, widths[i])).join(' | '));
  console.log(widths.map(w => '-'.repeat(w)).join('-+-'));
  for (const row of body) {
    console.log(row.map((c, i) => pad(c, widths[i])).join(' | '));
  }
  console.log(`\n${rows.length} of ${total} rows  (table ${tableId})`);
}

async function cmdDocs(flags) {
  const path = flags.api ? '/cli/API-REFERENCE.md' : '/cli/AGENT-X-GUIDE.md';
  const url = `${BASE_URL}${path}`;
  if (flags.url) { console.log(url); return; }
  const res = await fetch(url);
  if (!res.ok) {
    throw new Error(`docs fetch failed: GET ${url} -> ${res.status}`);
  }
  process.stdout.write(await res.text());
}

function usage() {
  console.log(`agent-x — terminal client for DataFlow Agent X (GTM Campaign Builder)

Commands:
  new   "<prompt>"        [--model <id>]   start a new conversation
  turn  <id> "<message>"  [--model <id>]   append a follow-up turn
  get   <id>                               show conversation + campaign status
  preview <id>                             run search-count preview
  launch  <id>            [--limit <n>]    launch the approved plan as a campaign
  list                                     list recent conversations
  delete <id>                              delete a conversation
  set-key <token>                          save DATAFLOW_API_KEY to ~/.config/agent-x/env
  set-base-url <url>                       save DATAFLOW_BASE_URL to ~/.config/agent-x/env
  api <METHOD> <path> [opts]               passthrough to any /api/* endpoint
                                             opts: --data <json>, --data-file <path>,
                                                   --query k=v (repeatable)
  view <tableId> [opts]                    pretty-print rows from a sheet
                                             opts: --limit N (default 20),
                                                   --cols a,b,c (substring match),
                                                   --filter <json>, --wide, --json
  docs [--api] [--url]                     fetch and print AGENT-X-GUIDE.md
                                             --api: only the endpoint reference
                                             --url: just print the URL

Config (override precedence): env vars > ~/.config/agent-x/env > defaults
  DATAFLOW_BASE_URL  (default: https://dataflow-pi.vercel.app)
  DATAFLOW_API_KEY   (bearer token for /api/* endpoints)

Examples (driving the workbook API directly):
  agent-x api GET /api/projects
  agent-x api POST /api/tables --data '{"projectId":"p_...","name":"Companies"}'
  agent-x api GET /api/rows --query tableId=t_xxx --query 'filterLogic=AND'
  agent-x view <tableId> --limit 5 --cols name,domain
  agent-x docs | less                      # full guide (CLI + API)
  agent-x docs --api                       # just the API reference`);
}

async function main() {
  const [cmd, ...rest] = process.argv.slice(2);
  if (!cmd || cmd === 'help' || cmd === '--help' || cmd === '-h') { usage(); return; }
  // `api` has its own arg shape (repeatable --query); handle before the
  // generic parseFlags which would collapse repeats.
  if (cmd === 'api') return cmdApi(rest);
  const { positional, flags } = parseFlags(rest);
  switch (cmd) {
    case 'new':          return cmdNew(positional, flags);
    case 'turn':         return cmdTurn(positional, flags);
    case 'get':          return cmdGet(positional);
    case 'preview':      return cmdPreview(positional);
    case 'launch':       return cmdLaunch(positional, flags);
    case 'list':         return cmdList();
    case 'delete':       return cmdDelete(positional);
    case 'set-key':      return cmdSetKey(positional);
    case 'set-base-url': return cmdSetBaseUrl(positional);
    case 'docs':         return cmdDocs(flags);
    case 'view':         return cmdView(positional, flags);
    default:
      usage();
      process.exitCode = 1;
  }
}

main().catch(err => {
  console.error(err instanceof Error ? err.message : err);
  process.exitCode = 1;
});
